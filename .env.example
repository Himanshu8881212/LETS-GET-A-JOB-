# ────────────────────────────────────────────────────────────────────────────
# LLM Provider Configuration
# ────────────────────────────────────────────────────────────────────────────
# Pick ONE default provider. All AI features use it unless overridden below.
#
#   kinds: openai-compatible | anthropic | google
#
# "openai-compatible" works for OpenAI, OpenRouter, Mistral, DeepSeek, Groq,
# xAI, Ollama (http://localhost:11434/v1), LM Studio (http://localhost:1234/v1).

LLM_PROVIDER=openai-compatible
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-key-here
# LLM_BASE_URL=https://api.openai.com/v1     # optional; defaults to OpenAI for openai-compatible
#
# Local examples:
#   LLM_PROVIDER=openai-compatible
#   LLM_BASE_URL=http://localhost:11434/v1   # Ollama
#   LLM_API_KEY=ollama
#   LLM_MODEL=qwen2.5:14b
#
#   LLM_PROVIDER=openai-compatible
#   LLM_BASE_URL=http://localhost:1234/v1    # LM Studio
#   LLM_API_KEY=lmstudio
#   LLM_MODEL=llama-3.1-70b-instruct
#
# Cloud examples:
#   LLM_PROVIDER=anthropic
#   LLM_API_KEY=sk-ant-...
#   LLM_MODEL=claude-sonnet-4-6
#
#   LLM_PROVIDER=openai-compatible
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_API_KEY=sk-or-...
#   LLM_MODEL=anthropic/claude-3.5-sonnet
#
#   LLM_PROVIDER=google
#   LLM_API_KEY=AIza...
#   LLM_MODEL=gemini-2.5-flash

# Optional per-feature overrides. Any field not set inherits from LLM_* above.
# Each prefix takes: _PROVIDER, _MODEL, _API_KEY, _BASE_URL
#   LLM_PARSE_JD_*, LLM_PARSE_RESUME_*, LLM_PARSE_COVER_LETTER_*
#   LLM_GENERATE_RESUME_*, LLM_GENERATE_COVER_LETTER_*
#   LLM_TAILOR_RESUME_*, LLM_TAILOR_COVER_LETTER_*
#   LLM_EVAL_*, LLM_SCOUT_*
#
# Example — route only the ATS evaluator to Claude while the rest stays local:
#   LLM_EVAL_PROVIDER=anthropic
#   LLM_EVAL_API_KEY=sk-ant-...
#   LLM_EVAL_MODEL=claude-sonnet-4-6
